# Copy to `.env` (gitignored) and fill in real values.
# The `researcher` agent (root tachyon.yml) declares an ISOLATED HARNESS with the
# Tavily web-search MCP; Tachyon resolves ${TAVILY_API_KEY} from this .env (or your
# shell env, which takes precedence) and injects it into that agent only — the value
# is never written into Tachyon's materialized config. Get a key at https://tavily.com.
TAVILY_API_KEY=
