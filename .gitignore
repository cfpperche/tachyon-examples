node_modules
# .tachyon holds runtime state (sessions.json, harness/, runs/) — ignored — EXCEPT
# pipeline definitions, which are source you version like tachyon.yml.
.tachyon/*
!.tachyon/pipelines/
.claude/
# real secrets for the isolated-harness demo (TAVILY_API_KEY) — never commit; see .env.example
.env
# .mcp.json is committed (portable: ${TACHYON_BRIDGE_URL}/${TACHYON_BRIDGE_TOKEN}
# are injected by Tachyon per session) so the demo's Bridge tools work on any clone
# without a manual "Tachyon: Connect". Running Connect overwrites it with a
# machine-specific literal URL — harmless, just revert the file to re-share.
